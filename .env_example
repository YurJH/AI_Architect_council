# =============================================================
# Option 1: Direct API keys (simplest)
# =============================================================
ANTHROPIC_API_KEY=sk-ant-...

# For Gemini: use GOOGLE_API_KEY (or GEMINI_API_KEY, auto-mapped at startup).
# If your key is from AI Studio's Vertex AI Express (aiplatform.googleapis.com),
# you MUST also set GOOGLE_GENAI_USE_VERTEXAI=true below.
GOOGLE_API_KEY=...
GOOGLE_GENAI_USE_VERTEXAI=true

# =============================================================
# Option 2: Google Cloud Vertex AI (uses GCP OAuth/service account)
# Uncomment and set the model overrides below.
# =============================================================
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# VERTEXAI_PROJECT=your-gcp-project
# VERTEXAI_LOCATION=us-east5
# SA_MODEL=vertex_ai/claude-opus-4-6
# ARCH_A_MODEL=vertex_ai/claude-sonnet-4-6

# =============================================================
# Option 3: AWS Bedrock (uses IAM credentials)
# Uncomment and set the model overrides below.
# =============================================================
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1
# SA_MODEL=bedrock/anthropic.claude-opus-4-6
# ARCH_A_MODEL=bedrock/anthropic.claude-sonnet-4-6

# =============================================================
# Optional: override default models per agent
# =============================================================
# SA_MODEL=gemini/gemini-3.1-pro-preview
# ARCH_A_MODEL=gemini/gemini-3.1-pro-preview
# ARCH_B_MODEL=gemini/gemini-3.1-pro-preview
